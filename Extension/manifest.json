{
  "manifest_version": 3,
  "name": "OSS Assistant",
  "version": "1.0.1",
  "description": "This extension automates workflows in A1 internal OSS portal",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "clipboardRead",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://oss.a1.bg/*",
    "https://oss.mobiltel.bg/*",
    "https://srvvm-webtst-0.mobiltel.bg/*",
    "https://oss-assistant.onrender.com/*",
    "https://oss-assistant.github.io/*",
    "https://raw.githubusercontent.com/AgLogiV/oss-assistant-extension/main/config/recycle-device-catalog.fixture.json",
    "https://raw.githubusercontent.com/AgLogiV/oss-assistant-extension/main/config/dailywork.json"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*.svg",
        "images/*.png",
        "images/devices/*.webp",
        "images/devices/16x9/*.webp",
        "images/categories/*.webp",
        "images/categories/16x9/*.webp",
        "images/recycle-help/*.webp"
      ],
      "matches": [
        "https://oss.a1.bg/*",
        "https://oss.mobiltel.bg/*",
        "https://srvvm-webtst-0.mobiltel.bg/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://oss.a1.bg/bbs2_1/sap-warehouse-recycle*",
        "https://oss.a1.bg/bbs2_1/wflow/device-recycle/*",
        "https://oss.a1.bg/bbs2_1/wflow/device-history/*",
        "https://oss.a1.bg/bbs2_1/wflow/recycle-state/*",
        "https://oss.a1.bg/bbs2_1/wflow/after-recycle-state/*",
        "https://oss.mobiltel.bg/bbs2_1/sap-warehouse-recycle*",
        "https://oss.mobiltel.bg/bbs2_1/wflow/device-recycle/*",
        "https://oss.mobiltel.bg/bbs2_1/wflow/device-history/*",
        "https://oss.mobiltel.bg/bbs2_1/wflow/recycle-state/*",
        "https://oss.mobiltel.bg/bbs2_1/wflow/after-recycle-state/*",
        "https://srvvm-webtst-0.mobiltel.bg/bbs2_1/sap-warehouse-recycle*",
        "https://srvvm-webtst-0.mobiltel.bg/bbs2_1/wflow/device-recycle/*",
        "https://srvvm-webtst-0.mobiltel.bg/bbs2_1/wflow/device-history/*",
        "https://srvvm-webtst-0.mobiltel.bg/bbs2_1/wflow/recycle-state/*",
        "https://srvvm-webtst-0.mobiltel.bg/bbs2_1/wflow/after-recycle-state/*"
      ],
      "css": [
        "recycle-theme.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://oss.a1.bg/*",
        "https://oss.mobiltel.bg/*",
        "https://srvvm-webtst-0.mobiltel.bg/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://a1g.sharepoint.com/sites/o365RCR/Lists/OSSRecycleSchedule/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://oss.a1.bg/rcbill/*",
        "https://oss.a1.bg/RCBill/*",
        "https://oss.a1.bg/bbs2/*"
      ],
      "css": [
        "bbs-assistant/content.css"
      ],
      "js": [
        "bbs-assistant/dom-utils.js",
        "bbs-assistant/page-detector.js",
        "bbs-assistant/mac-search.js",
        "bbs-assistant/ui-panel.js",
        "bbs-assistant/content.js",
        "bbs-assistant/contract-bridge.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
